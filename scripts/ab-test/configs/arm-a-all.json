{
  "name": "arm-a-all",
  "description": "Arm A (control): roz-mcp with ROZ_TOOLS=all (14 tools); production snippet injected. Reproduces the prior 14-tool config to anchor the stripping delta.",
  "inject_claude_md_snippet": true,
  "mcp_servers": {
    "roz": {
      "type": "stdio",
      "command": "roz-mcp",
      "env": { "ROZ_TOOLS": "all" }
    }
  },
  "extra_allowed_tools": [
    "mcp__roz__find_symbol",
    "mcp__roz__get_symbols_overview",
    "mcp__roz__go_to_definition",
    "mcp__roz__find_overloads",
    "mcp__roz__find_references",
    "mcp__roz__find_implementations",
    "mcp__roz__get_type_hierarchy",
    "mcp__roz__edit_symbol",
    "mcp__roz__rename_symbol",
    "mcp__roz__replace_content",
    "mcp__roz__add_usings",
    "mcp__roz__remove_unused_usings",
    "mcp__roz__get_diagnostics",
    "mcp__roz__get_workspace_info"
  ]
}
