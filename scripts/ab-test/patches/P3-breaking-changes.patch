@@ -0,0 +1,20 @@
+namespace Nop.Core.Security;
+
+/// <summary>
+/// Internal metadata describing the active encryption-key format. Used only within Nop.Core.
+/// </summary>
+internal static class EncryptionKeyMetadata
+{
+    /// <summary>
+    /// The internal revision of the key-derivation format.
+    /// </summary>
+    internal const int KeyFormatRevision = 2;
+
+    /// <summary>
+    /// Returns a short label describing the current key format.
+    /// </summary>
+    internal static string DescribeFormat()
+    {
+        return $"nop-key-v{KeyFormatRevision}";
+    }
+}
